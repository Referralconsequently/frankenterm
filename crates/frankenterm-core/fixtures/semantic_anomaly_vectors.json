      "embedding": [0.85, 0.12, 0.06, 0.03, 0.01, 0.01, 0.0, 0.0],
      "expected_entropy_bpb": 2.1
    },
    "html_404": {
      "label": "404 Not Found <html><body><h1>Not Found</h1></body></html>",
      "embedding": [0.0, 0.0, 0.01, 0.01, 0.02, 0.05, 0.9, 0.8],
      "expected_entropy_bpb": 4.5
    },
    "test_passed": {
      "label": "test result: ok. 42 passed; 0 failed; 0 ignored",
      "embedding": [0.3, 0.1, 0.05, 0.02, 0.5, 0.3, 0.01, 0.0],
