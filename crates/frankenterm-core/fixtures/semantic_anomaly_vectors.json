  "test_scenarios": [
    {
      "name": "stable_then_orthogonal_shift",
      "description": "30 Rust compile observations then a Java NPE (orthogonal context)",
      "stable_vector": "rust_compile",
      "stable_count": 30,
      "shift_vector": "java_npe",
      "expected": "anomaly_detected"
    },
    {
      "name": "stable_then_similar",
      "description": "30 Rust compile observations then a build progress (similar context)",
      "stable_vector": "rust_compile",
      "stable_count": 30,
      "shift_vector": "build_progress",
      "expected": "no_anomaly"
    },
    {
      "name": "stable_then_html_404",
      "description": "30 Rust compile observations then HTML 404 (completely orthogonal)",
      "stable_vector": "rust_compile",
      "stable_count": 30,
      "shift_vector": "html_404",
      "expected": "anomaly_detected"
    }
  ]
