# Rust build artifacts
target/
target-*/
**/*.rs.bk
Cargo.lock.bak

# Tracked Cargo config lives in .cargo/config.toml; use the example/template
# and extra per-agent override files for machine-local adjustments.

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# macOS resource forks
._*

# Environment and secrets
.env
.env.*
*.pem
*.key

# Beads viewer local config
.bv/

# Beads lock files (bv viewer lock, br sync lock, etc.)
.beads/*.lock

# Legacy WezTerm source (vendored for reference)
legacy_wezterm/

# Legacy Ghostty source (vendored for reference)
legacy_ghostty/

# Legacy Zellij source (vendored for reference)
legacy_zellij/

# Legacy Rio source (vendored for reference)
legacy_rio/

# SQLite databases (runtime)
*.db
*.db-journal
*.db-wal
*.db-shm

# Log files
*.log
logs/

# Test artifacts
test_output/
coverage/
*.profraw
*.profdata

# Temporary files
tmp/
temp/
*.tmp

# Generated documentation (build on demand)
doc/
.ntm/

# E2E test artifacts (runtime)
e2e-artifacts/

# Local ft runtime/config
.ft/

# Fuzzing artifacts
fuzz/artifacts/

# Compiled binaries
a.out

# Agent-named target directories (concurrent agent builds)
target_*/

# bv triage artifacts (auto-generated, ephemeral)
brief.md
helpers.md
insights.json
meta.json
triage.json

# Proptest regression files (auto-generated, machine-specific)
**/proptest-regressions/
*.proptest-regressions

# TLA+ model checker generated state files (multi-GB, regeneratable)
docs/formal/states/
docs/formal/*.tlc.log

# WezTerm Automata runtime state (backups, locks)
.wa/

# Per-agent Cargo caches (concurrent agent builds use isolated registries)
.cargo_*/
.cargo-*/

# Remote compilation helper cache and build artifacts
.rch/
.rch-target/

# Agent mail SQLite databases (runtime state, not project data)
storage.sqlite3
storage.sqlite3-*
storage.sqlite3.bak

# Beads backup files (auto-generated during sync/migration)
.beads/*.bak*

# Codegen sub-crate lock files (generated, not the workspace root Cargo.lock)
**/codegen/Cargo.lock

# ML model caches (fastembed, ONNX, etc.)
.fastembed_cache/
.onnx_cache/

# macOS app bundles (build output)
*.app/

# Scratch/throwaway files (agent experiments, one-off debugging)
*.orig
*.patch
*.bak
/test_*
.write_probe
**/test_bug.rs
**/test_deadlock.rs
**/*_bug_test.rs
**/*_test_bug.rs
/frankenredis/

# Agent worktree target directories (dot-prefixed)
.target-*/

# Agent mail project ID (runtime state)
.agent-mail-project-id

# MCP config files (editor/agent-specific, contain local paths/tokens)
*.mcp.json
opencode.json

# Agent-generated Python scripts (one-off fix/refactor/update tools)
fix_*.py
refactor_*.py
update_*.py

# E2E test artifacts (runtime output)
tests/e2e/artifacts/

# UBS (Ultimate Bug Scanner) reports
ubs*.txt

# Ephemeral regex/test scratch directories (agent experiments)
tmp_re_test/

# Agent tool MCP config backups (timestamped .bak files)
.claude/*.bak
.cline.mcp.json.*
.codex.mcp.json.*
.cursor.mcp.json.*
.gemini.mcp.json.*
.opencode.json.*
.windsurf.mcp.json.*
.claude/settings.local.json
